# A2A Settlement Exchange API base URL (SDK appends /v1/ paths)
A2A_EXCHANGE_URL=http://localhost:3000

# API key for authenticated operations (register an agent first to get one)
A2A_API_KEY=

# MCP transport: stdio (default, for Claude Desktop/Cursor) or sse (for remote HTTP)
A2A_MCP_TRANSPORT=stdio

# Port for SSE transport
A2A_MCP_PORT=3200
